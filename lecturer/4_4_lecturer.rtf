import \{ test, describe, before, after, beforeEach \} from "node:test";\line
import assert from "node:assert/strict";\line
import mongoose from "mongoose";\line
import \{ Task \} from "../src/models/task.model.js";\line
import * as taskService from "../src/services/tasks.service.js";\line
\line
const TEST_USER_ID = new mongoose.Types.ObjectId();\line
\line
describe("Task Service", () => \{\line
  before(async () => \{\line
    await mongoose.connect(\line
      process.env.MONGODB_URI_TEST ?? "mongodb://localhost:27017/test_db"\line
    );\line
  \});\line
\line
  after(async () => \{\line
    await mongoose.connection.dropDatabase();\line
    await mongoose.disconnect();\line
  \});\line
\line
  beforeEach(async () => \{\line
    await Task.deleteMany(\{\});\line
  \});\line
\line
  test("should create a task", async () => \{\line
    const task = await taskService.create(\line
      \{ title: "Test Task" \},\line
      TEST_USER_ID.toString()\line
    );\line
    assert.equal(task.title, "Test Task");\line
    assert.equal(task.status, "todo");\line
    assert.ok(task._id);\line
  \});\line
\line
  test("should throw 404 for non-existent task", async () => \{\line
    const fakeId = new mongoose.Types.ObjectId().toString();\line
    await assert.rejects(\line
      () => taskService.findById(fakeId, TEST_USER_ID.toString()),\line
      \{ message: "Task not found" \}\line
    );\line
  \});\line
\});\line
\par}
