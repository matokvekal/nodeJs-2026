import \{ test \} from "node:test";\line
import assert from "node:assert/strict";\line
import \{ fetch \} from "undici";\line
\line
test("POST /api/tasks creates a task", async () => \{\line
  // 1. Login first\line
  const loginRes = await fetch("http://localhost:3000/auth/login", \{\line
    method: "POST",\line
    headers: \{ "Content-Type": "application/json" \},\line
    body: JSON.stringify(\{ email: "test@test.com", password: "test123" \})\line
  \});\line
  const \{ accessToken \} = await loginRes.json();\line
\line
  // 2. Create task\line
  const res = await fetch("http://localhost:3000/api/v1/tasks", \{\line
    method: "POST",\line
    headers: \{\line
      "Content-Type": "application/json",\line
      Authorization: `Bearer $\{accessToken\}`\line
    \},\line
    body: JSON.stringify(\{ title: "My Task", priority: "high" \})\line
  \});\line
\line
  assert.equal(res.status, 201);\line
  const body = await res.json();\line
  assert.equal(body.data.title, "My Task");\line
\});\line
\par}
