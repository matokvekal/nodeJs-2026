import * as emailService from "../src/services/email.service.js";\line
import \{ UserService \} from "../src/services/user.service.js";\line
\line
test("sends welcome email on user creation", async (t) => \{\line
  // Mock the email service\line
  const sendEmailMock = t.mock.method(emailService, "sendWelcome", async () => \{\line
    return \{ sent: true \};\line
  \});\line
\line
  const userService = new UserService(emailService);\line
  await userService.register(\{ name: "Alice", email: "alice@test.com" \});\line
\line
  assert.equal(sendEmailMock.mock.calls.length, 1);\line
  assert.equal(sendEmailMock.mock.calls[0].arguments[0], "alice@test.com");\line
\});\line
