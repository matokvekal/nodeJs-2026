// \u10060? \u1500?\u1488? \u1489?\u1496?\u1493?\u1495? - \u1502?\u1513?\u1514?\u1502?\u1513? \u1497?\u1499?\u1493?\u1500? \u1500?\u1490?\u1513?\u1514? \u1500?task \u1513?\u1500? \u1488?\u1495?\u1512?\line
const task = await Task.findById(req.params.id);\line
\line
// \u9989? \u1489?\u1496?\u1493?\u1495? - ownership check\line
const task = await Task.findOne(\{ _id: req.params.id, user: req.user.id \});\line
if (!task) throw new AppError("Not found", 404);\line
\par}
