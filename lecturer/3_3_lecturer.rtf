{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 11 \u8211? Auth Middleware\par}
{\pard\rtlpar\par}
{\pard\rtlpar \\*\\*\u1491?\u1493?\u1490?\u1502?\u1492?:\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
export async function authenticate(req, res, next) \{\line
  const authHeader = req.headers.authorization;\line
  if (!authHeader?.startsWith("Bearer ")) \{\line
    throw new AppError("No token", 401);\line
  \}\line
\line
  const token = authHeader.split(" ")[1];\line
  const payload = jwt.verify(token, process.env.JWT_SECRET);\line
\line
  const isBlacklisted = await redis.exists(`blacklist:$\{payload.jti\}`);\line
  if (isBlacklisted) throw new AppError("Token revoked", 401);\line
\line
  req.user = payload;\line
  next();\line
\}\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar\brdrb\brdrs\brdrw10\brsp20 \par}
{\pard\rtlpar\par}
{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 12 \u8211? RBAC\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b Role-Based Access Control:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
export function authorize(...roles) \{\line
  return (req, res, next) => \{\line
    if (!roles.includes(req.user.role)) \{\line
      throw new AppError("Forbidden", 403);\line
    \}\line
    next();\line
  \};\line
\}\line
\line
// usage\line
router.delete("/:id", authenticate, authorize("admin"), deleteUser);\line
\par}
