{\pard\rtlpar\par}
{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 7 \u8211? Blacklist \u1506?\u1501? Redis\par}
{\pard\rtlpar\par}
{\pard\rtlpar \\*\\*\u1491?\u1493?\u1490?\u1502?\u1492?:\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
import \{ createClient \} from "redis";\line
const redis = createClient();\line
\line
// logout - blacklist the access token\line
export async function logout(req, res) \{\line
  const token = req.headers.authorization?.split(" ")[1];\line
  const payload = jwt.decode(token);\line
  const ttl = payload.exp - Math.floor(Date.now() / 1000);\line
\line
  await redis.setEx(`blacklist:$\{payload.jti\}`, ttl, "1");\line
\line
  // delete refresh token\line
  res.clearCookie("refreshToken");\line
  res.json(\{ message: "Logged out" \});\line
\}\line
\line
// middleware check\line
const isBlacklisted = await redis.exists(`blacklist:$\{payload.jti\}`);\line
if (isBlacklisted) throw new AppError("Token revoked", 401);\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar\brdrb\brdrs\brdrw10\brsp20 \par}
