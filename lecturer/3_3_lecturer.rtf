{\pard\rtlpar\par}
{\pard\rtlpar \\*\\*\u1494?\u1512?\u1497?\u1502?\u1514? Authentication:\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
Login:\line
  POST /auth/login \u8594? \{ email, password \}\line
  \u8592? Access Token (15m) + Refresh Token (7d) [HttpOnly Cookie]\line
\line
Request:\line
  GET /api/users \u8594? Authorization: Bearer <access_token>\line
  \u8592? 200 data\line
\line
Refresh:\line
  POST /auth/refresh \u8594? Cookie: refreshToken=<token>\line
  \u8592? new Access Token + new Refresh Token [rotation!]\line
\line
Logout:\line
  POST /auth/logout \u8594? Cookie: refreshToken=<token>\line
  \u8592? blacklist access token + delete refresh token\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar\brdrb\brdrs\brdrw10\brsp20 \par}
{\pard\rtlpar\par}
{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 5 \u8211? Token Rotation\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b \u1491?\u1493?\u1490?\u1502?\u1514? refresh flow:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
export async function refresh(req, res) \{\line
  const token = req.cookies.refreshToken;\line
  if (!token) throw new AppError("No refresh token", 401);\line
\line
  // 1. \u1488?\u1502?\u1514? \u1488?\u1514? \u1492?refresh token\line
  const payload = jwt.verify(token, process.env.REFRESH_SECRET);\line
\line
  // 2. \u1489?\u1491?\u1493?\u1511? \u1513?\u1492?\u1493?\u1488? \u1511?\u1497?\u1497?\u1501? \u1489?-DB (\u1500?\u1488? \u1504?\u1502?\u1495?\u1511?)\line
  const stored = await RefreshToken.findOne(\{ token, userId: payload.sub \});\line
  if (!stored) \{\line
    // ROTATION ATTACK! \u1502?\u1495?\u1511? \u1488?\u1514? \u1499?\u1500? \u1492?tokens \u1513?\u1500? \u1492?\u1502?\u1513?\u1514?\u1502?\u1513?\line
    await RefreshToken.deleteMany(\{ userId: payload.sub \});\line
    throw new AppError("Refresh token reuse detected", 401);\line
  \}\line
\line
  // 3. \u1502?\u1495?\u1511? \u1497?\u1513?\u1503?, \u1510?\u1493?\u1512? \u1495?\u1491?\u1513?\line
  await stored.deleteOne();\line
  const \{ accessToken, refreshToken \} = await generateTokens(payload.sub);\line
\line
  res.cookie("refreshToken", refreshToken, \{\line
    httpOnly: true,\line
    sameSite: "strict"\line
  \});\line
  res.json(\{ accessToken \});\line
\}\line
\par}
{\pard\rtlpar\par}
