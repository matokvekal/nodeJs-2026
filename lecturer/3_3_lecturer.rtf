{\pard\rtlpar\par}
{\pard\rtlpar\li360\fi-360 \u8226? Access Token: 15 \u1491?\u1511?\u1493?\u1514? \u8211? \u1488?\u1501? \u1504?\u1490?\u1504?\u1489?, \u1514?\u1493?\u1511?\u1507? \u1508?\u1490? \u1502?\u1492?\u1512?\par}
{\pard\rtlpar\li360\fi-360 \u8226? Refresh Token: 7 \u1497?\u1502?\u1497?\u1501? \u8211? \u1502?\u1488?\u1508?\u1513?\u1512? \u1513?\u1497?\u1502?\u1493?\u1513? \u1504?\u1493?\u1495? \u1500?\u1500?\u1488? login \u1495?\u1493?\u1494?\u1512?\par}
