import \{ DataTypes \} from "sequelize";\line
import \{ sequelize \} from "../config/db.js";\line
\line
export const User = sequelize.define(\line
  "User",\line
  \{\line
    name: \{ type: DataTypes.STRING, allowNull: false \},\line
    email: \{\line
      type: DataTypes.STRING,\line
      allowNull: false,\line
      unique: true,\line
      validate: \{ isEmail: true \}\line
    \},\line
    role: \{ type: DataTypes.ENUM("user", "admin"), defaultValue: "user" \}\line
  \},\line
  \{ tableName: "users" \}\line
);\line
\par}
