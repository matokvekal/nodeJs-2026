import \{ Sequelize \} from "sequelize";\line
\line
export const sequelize = new Sequelize(process.env.DATABASE_URL, \{\line
  dialect: "postgres",\line
  logging: (sql) => logger.debug(sql),\line
  pool: \{ max: 10, min: 2, idle: 10000 \}\line
\});\line
\line
export async function connectDB() \{\line
  await sequelize.authenticate();\line
  console.log("PostgreSQL connected");\line
\}\line
\par}
