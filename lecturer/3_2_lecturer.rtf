{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
const result = await sequelize.transaction(async (t) => \{\line
  const sender = await Account.findByPk(1, \{ transaction: t, lock: true \});\line
  const receiver = await Account.findByPk(2, \{ transaction: t, lock: true \});\line
\line
  if (sender.balance < 100) throw new AppError("Insufficient balance", 400);\line
\line
  await sender.decrement("balance", \{ by: 100, transaction: t \});\line
  await receiver.increment("balance", \{ by: 100, transaction: t \});\line
\line
  return \{ success: true \};\line
\});\line
\par}
