  where: \{ role: "admin" \},\line
  attributes: ["name", "email"]\line
\});\line
\line
// Update\line
await user.update(\{ name: "Alice Smith" \});\line
\line
// Delete\line
await User.destroy(\{ where: \{ id: 5 \} \});\line
\par}
