{\pard\ltrpar\f1\fs18\cf1
import \{ createCipheriv, createDecipheriv, randomBytes \} from "node:crypto";\line
\line
const KEY = randomBytes(32); // AES-256\line
const IV = randomBytes(16);\line
\line
function encrypt(text) \{\line
  const cipher = createCipheriv("aes-256-gcm", KEY, IV);\line
  const encrypted = Buffer.concat([\line
    cipher.update(text, "utf8"),\line
    cipher.final()\line
  ]);\line
  const tag = cipher.getAuthTag();\line
  return \{\line
    data: encrypted.toString("hex"),\line
    tag: tag.toString("hex"),\line
    iv: IV.toString("hex")\line
  \};\line
\}\line
\line
function decrypt(\{ data, tag, iv \}) \{\line
  const decipher = createDecipheriv("aes-256-gcm", KEY, Buffer.from(iv, "hex"));\line
  decipher.setAuthTag(Buffer.from(tag, "hex"));\line
  return (\line
    decipher.update(Buffer.from(data, "hex"), null, "utf8") +\line
    decipher.final("utf8")\line
  );\line
\}\line
\par}
