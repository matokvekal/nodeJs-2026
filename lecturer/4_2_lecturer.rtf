{\pard\ltrpar\f1\fs18\cf1
import \{ createHmac \} from "node:crypto";\line
\line
const secret = "my_webhook_secret";\line
const body = JSON.stringify(\{ event: "payment.success", amount: 100 \});\line
\line
// Sign\line
const signature = createHmac("sha256", secret).update(body).digest("hex");\line
console.log("Signature:", signature);\line
\line
// Verify (receiver side)\line
function verifyWebhook(receivedBody, receivedSig, secret) \{\line
  const expected = createHmac("sha256", secret)\line
    .update(receivedBody)\line
    .digest("hex");\line
  return expected === receivedSig;\line
\}\line
\par}
