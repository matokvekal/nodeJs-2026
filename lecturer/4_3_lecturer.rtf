// heavy-worker.js\line
import \{ workerData, parentPort \} from "node:worker_threads";\line
let sum = 0;\line
for (let i = 0; i < workerData.n; i++) sum += i;\line
parentPort.postMessage(\{ sum \});\line
\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
// app.js\line
import \{ Worker \} from "node:worker_threads";\line
\line
app.get("/heavy", (req, res) => \{\line
  const worker = new Worker("./heavy-worker.js", \{\line
    workerData: \{ n: 1e9 \}\line
  \});\line
  worker.on("message", (result) => res.json(result));\line
  worker.on("error", (err) => res.status(500).json(\{ error: err.message \}));\line
\});\line
\par}
