{\pard\ltrpar\f1\fs18\cf1
import \{ AsyncLocalStorage \} from "node:async_hooks";\line
import \{ randomUUID \} from "node:crypto";\line
\line
const requestContext = new AsyncLocalStorage();\line
\line
// Express middleware\line
app.use((req, res, next) => \{\line
  const context = \{\line
    requestId: randomUUID(),\line
    userId: req.user?.id,\line
    startTime: Date.now()\line
  \};\line
  requestContext.run(context, next);\line
\});\line
\line
// Logger helper\line
function log(level, message, extra = \{\}) \{\line
  const ctx = requestContext.getStore() ?? \{\};\line
  console.log(JSON.stringify(\{ level, message, ...ctx, ...extra \}));\line
\}\line
\line
// \u1489?service \u8211? \u1488?\u1497?\u1503? req, \u1488?\u1489?\u1500? \u1497?\u1513? context\line
async function processOrder(orderId) \{\line
  log("info", "Processing order", \{ orderId \});\line
  // ...\line
\}\line
\par}
