import \{ EventEmitter \} from "node:events";\line
\line
class OrderService extends EventEmitter \{\line
  async createOrder(data) \{\line
    const order = await Order.create(data);\line
    this.emit("order:created", order);\line
    return order;\line
  \}\line
\}\line
\line
const orderService = new OrderService();\line
\line
// \u1513?\u1497?\u1512?\u1493?\u1514? email \u1500?\u1488? \u1502?\u1499?\u1497?\u1512? \u1488?\u1514? OrderService\line
orderService.on("order:created", async (order) => \{\line
  await emailService.sendConfirmation(order.email, order);\line
\});\line
\line
// \u1513?\u1497?\u1512?\u1493?\u1514? inventory \u1500?\u1488? \u1502?\u1499?\u1497?\u1512? \u1488?\u1514? OrderService\line
