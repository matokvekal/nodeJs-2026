import \{ z \} from "zod";\line
\line
export const createUserSchema = z.object(\{\line
  name: z.string().min(2).max(50),\line
  email: z.string().email(),\line
  age: z.number().int().min(18).optional()\line
\});\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b `src/middleware/validate.js`:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
export function validate(schema) \{\line
  return (req, res, next) => \{\line
    const result = schema.safeParse(req.body);\line
    if (!result.success) \{\line
      return res.status(422).json(\{\line
        status: 422,\line
        title: "Validation Error",\line
        errors: result.error.flatten().fieldErrors\line
      \});\line
    \}\line
    req.validatedData = result.data;\line
    next();\line
  \};\line
\}\line
\par}
