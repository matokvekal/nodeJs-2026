// Express 4 \u8592? \u1489?\u1506?\u1497?\u1493?\u1514? \u1506?\u1501? async\line
app.get("/users/:id", async (req, res, next) => \{\line
  try \{\line
    const user = await findUser(req.params.id);\line
    res.json(user);\line
  \} catch (err) \{\line
    next(err); // \u8592? \u1495?\u1493?\u1489?\u1492? \u1497?\u1491?\u1504?\u1497?\u1514?\line
  \}\line
\});\line
\line
// Express 5 \u8592? \u1488?\u1493?\u1496?\u1493?\u1502?\u1496?\u1497?!\line
app.get("/users/:id", async (req, res) => \{\line
  const user = await findUser(req.params.id); // throw \u8594? error middleware\line
  res.json(user);\line
\});\line
\par}
