import * as userService from "../services/users.service.js";\line
\line
export async function getAll(req, res) \{\line
  const users = await userService.findAll(req.query);\line
  res.json(\{ data: users \});\line
\}\line
\line
export async function getOne(req, res) \{\line
  const user = await userService.findById(req.params.id);\line
  res.json(\{ data: user \});\line
\}\line
\line
export async function create(req, res) \{\line
  const user = await userService.create(req.validatedData);\line
  res.status(201).json(\{ data: user \});\line
\}\line
\par}
