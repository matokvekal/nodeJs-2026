import \{ Router \} from "express";\line
import * as usersController from "../controllers/users.controller.js";\line
import \{ validate \} from "../middleware/validate.js";\line
import \{ createUserSchema \} from "../schemas/user.schema.js";\line
\line
const router = Router();\line
\line
router\line
  .route("/")\line
  .get(usersController.getAll)\line
  .post(validate(createUserSchema), usersController.create);\line
\line
router\line
  .route("/:id")\line
  .get(usersController.getOne)\line
  .put(validate(createUserSchema.partial()), usersController.update)\line
  .delete(usersController.remove);\line
\line
export default router;\line
\par}
