import mongoose from "mongoose";\line
\line
const taskSchema = new mongoose.Schema(\line
  \{\line
    title: \{\line
      type: String,\line
      required: [true, "Title is required"],\line
      maxlength: 100\line
    \},\line
    description: \{ type: String, maxlength: 500 \},\line
    status: \{\line
      type: String,\line
      enum: ["todo", "in-progress", "done"],\line
      default: "todo"\line
    \},\line
    priority: \{\line
      type: String,\line
      enum: ["low", "medium", "high"],\line
      default: "medium"\line
    \},\line
    user: \{ type: mongoose.Schema.Types.ObjectId, ref: "User", required: true \},\line
    dueDate: Date\line
  \},\line
  \{ timestamps: true \}\line
);\line
\line
// \u1488?\u1497?\u1504?\u1491?\u1511?\u1505?\u1497?\u1501?\line
taskSchema.index(\{ user: 1, status: 1 \});\line
taskSchema.index(\{ createdAt: -1 \});\line
\line
export const Task = mongoose.model("Task", taskSchema);\line
\par}
