import \{ Task \} from "../models/task.model.js";\line
import \{ AppError \} from "../utils/AppError.js";\line
\line
export async function findAll(\{ userId, status, sort = "-createdAt" \}) \{\line
  const filter = \{ user: userId \};\line
  if (status) filter.status = status;\line
  return Task.find(filter).sort(sort).lean();\line
\}\line
\line
export async function findById(id, userId) \{\line
  const task = await Task.findOne(\{ _id: id, user: userId \}).lean();\line
  if (!task) throw new AppError("Task not found", 404);\line
  return task;\line
\}\line
\line
export async function create(data, userId) \{\line
  return Task.create(\{ ...data, user: userId \});\line
\}\line
\par}
