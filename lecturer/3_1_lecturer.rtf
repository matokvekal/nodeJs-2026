{\pard\rtlpar {\b Cursor pagination \u1491?\u1493?\u1490?\u1502?\u1492?:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
export async function findAll(\{ after, limit = 20, userId \}) \{\line
  const query = \{ user: userId \};\line
  if (after) query._id = \{ $gt: after \};\line
\line
  const tasks = await Task.find(query)\line
    .sort(\{ _id: 1 \})\line
    .limit(limit + 1)\line
    .lean();\line
\line
  const hasMore = tasks.length > limit;\line
  return \{\line
    data: hasMore ? tasks.slice(0, -1) : tasks,\line
    nextCursor: hasMore ? tasks.at(-2)._id : null\line
  \};\line
\}\line
\par}
