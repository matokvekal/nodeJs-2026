{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 7 \u8211? Private Messages\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b \u1491?\u1493?\u1490?\u1502?\u1492?:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
const clients = new Map(); // userId \u8594? ws\line
\line
wss.on("connection", (ws, req) => \{\line
  const userId = new URL(req.url, "http://localhost").searchParams.get(\line
    "userId"\line
  );\line
  clients.set(userId, ws);\line
\line
  ws.on("close", () => clients.delete(userId));\line
\line
  ws.on("message", (data) => \{\line
    const msg = JSON.parse(data.toString());\line
    if (msg.type === "private") \{\line
      const targetWs = clients.get(msg.to);\line
      if (targetWs?.readyState === WebSocket.OPEN) \{\line
        targetWs.send(\line
          JSON.stringify(\{ type: "private", from: userId, text: msg.text \})\line
        );\line
      \}\line
    \}\line
  \});\line
\});\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar\brdrb\brdrs\brdrw10\brsp20 \par}
{\pard\rtlpar\par}
{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 8 \u8211? Ping/Pong\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b \u1491?\u1493?\u1490?\u1502?\u1514? heartbeat:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
wss.on("connection", (ws) => \{\line
  ws.isAlive = true;\line
  ws.on("pong", () => \{\line
    ws.isAlive = true;\line
  \});\line
\});\line
\line
const heartbeat = setInterval(() => \{\line
  wss.clients.forEach((ws) => \{\line
    if (!ws.isAlive) \{\line
      console.log("Terminating zombie connection");\line
      return ws.terminate();\line
    \}\line
    ws.isAlive = false;\line
    ws.ping();\line
  \});\line
\}, 30_000);\line
\line
wss.on("close", () => clearInterval(heartbeat));\line
\par}
