{\pard\rtlpar\b\fs28 \u1513?\u1511?\u1507? 6 \u8211? Broadcast\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b \u1491?\u1493?\u1490?\u1502?\u1492?:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
function broadcast(wss, message, excludeWs = null) \{\line
  const json = JSON.stringify(message);\line
  wss.clients.forEach((client) => \{\line
    if (client !== excludeWs && client.readyState === WebSocket.OPEN) \{\line
      client.send(json);\line
    \}\line
  \});\line
\}\line
\line
wss.on("connection", (ws) => \{\line
  ws.on("message", (data) => \{\line
    const msg = JSON.parse(data.toString());\line
    if (msg.type === "chat") \{\line
      broadcast(wss, \{ type: "chat", text: msg.text, from: "user" \}, ws);\line
    \}\line
  \});\line
\});\line
\par}
{\pard\rtlpar\par}
{\pard\rtlpar {\b \u1489?\u1491?\u1497?\u1511?\u1492?:} \u1508?\u1514?\u1497?\u1495?\u1514? 2 browser tabs \u1493?\u1492?\u1491?\u1490?\u1502?\u1514? \u1513?\u1492?\u1493?\u1491?\u1506?\u1492? \u1502?-tab \u1488?\u1495?\u1491? \u1502?\u1490?\u1497?\u1506?\u1492? \u1500?\u1513?\u1504?\u1497?.\par}
