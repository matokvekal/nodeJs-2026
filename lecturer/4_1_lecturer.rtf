{\pard\rtlpar {\b \u1491?\u1493?\u1490?\u1502?\u1514? `server.js`:}\par}
{\pard\rtlpar\par}
{\pard\ltrpar\f1\fs18\cf1
import \{ WebSocketServer, WebSocket \} from "ws";\line
import \{ createServer \} from "node:http";\line
import express from "express";\line
\line
const app = express();\line
const httpServer = createServer(app);\line
const wss = new WebSocketServer(\{ server: httpServer \});\line
\line
wss.on("connection", (ws, req) => \{\line
  console.log("New client connected");\line
  ws.send(JSON.stringify(\{ type: "welcome", message: "Connected!" \}));\line
\line
  ws.on("message", (data) => \{\line
    const msg = JSON.parse(data.toString());\line
    console.log("Received:", msg);\line
    ws.send(JSON.stringify(\{ type: "echo", ...msg \}));\line
  \});\line
\line
  ws.on("close", (code) => console.log("Client disconnected, code:", code));\line
  ws.on("error", (err) => console.error("WebSocket error:", err));\line
\});\line
\line
httpServer.listen(3000);\line
\par}
